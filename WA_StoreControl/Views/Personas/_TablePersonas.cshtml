@model ModelosDB.General.Persona

<template id="table-Persona-template">
    <loading-spinner params="{ Loading: LoadingRegistros, Message: 'Cargando...' }"></loading-spinner>

    <div class="table-responsive">
        <table class="table table-hover" data-bind="if: (!LoadingRegistros() && Personas().length > 0)">
            <caption class="small fw-bold">
                <span data-bind="text: Personas().length"></span> registros en la tabla.
            </caption>
            <thead>
                <tr>
                    <th scope="row" class="text-center">
                        #
                    </th>
                    <th>
                        @Html.DisplayName("Identificación")
                    </th>
                    <th>
                        @Html.DisplayName("Nombre Completo")
                    </th>
                    <th>
                        @Html.DisplayName("Tipo")
                    </th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody class="table-group-divider" data-bind="foreach: Personas">
                <tr>
                    <td class="text-center align-middle fw-bold" data-bind="text: ((($parent.SearchViewModel().Page() - 1) * $parent.SearchViewModel().RecordsPerPage()) + $index() + 1)"></td>

                    <td class="align-middle" data-bind="text:CodigoIdentificacion" style="white-space: pre-line;"></td>
                    <td class="align-middle" data-bind="text:NombreCompleto"></td>
                    <td class="align-middle">
                        <span data-bind="css: EsPersonaNatural() ? 'badge text-bg-success' : 'badge text-bg-info',
                    text: EsPersonaNatural() ? 'Natural' : 'Jurídico'"></span>
                    </td>
                    <td>
                        <button type="button" class="btn btn-outline-primary" title="Editar" data-bind="click: () => { $root.ShowModal($data, 'Edit') }">
                            <i class="fa fa-pencil-square-o"></i>
                        </button>
                        <button type="button" class="btn btn-outline-warning" title="Detalles" data-bind="click: () => { $root.ShowModal($data, 'Details') }">
                            <i class="fa fa-info-circle"></i>
                        </button>
                        <button type="button" class="btn btn-outline-danger" title="Eliminar" data-bind="click: () => { $root.ShowModal($data, 'Delete') }">
                            <i class="fa fa-trash"></i>
                        </button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
    <!--ko if: LoadingRegistros() === false -->
    <div class="mt-3" data-bind="template: { name: 'pagination-template', data: PaginationViewModel }"></div>
    <!--/ko-->
    <!--ko if: (Personas().length <= 0 && !LoadingRegistros()) -->
    <div class="alert alert-warning animated flash mb-0" role="alert">
        <p class="mb-0">
            <span class="fas fa-exclamation-triangle"></span>
            No se han encontrado @ViewBag.Title para mostrar
        </p>
    </div>
    <!--/ko -->
</template>