@model ModelosSIGI.Finanzas.Tercero

<template id="template-listado-terceros">
    <!--ko if: LoadingRegistros() -->
    <div data-bind="template: { name: 'loading-spinner-template', data: { Loading: true, Message: 'Cargando...' } }"></div>
    <!--/ko-->

    <div class="table-responsive" data-bind="if: (!LoadingRegistros() && terceros().length > 0)">
        <table class="table table-hover table-sm small">
            <caption class="small fw-bold caption-top">
                <span data-bind="text: (SearchViewModel().RecordsPerPage() == terceros().length ? (SearchViewModel().RecordsPerPage() * PaginationViewModel().CurrentPage()) : (SearchViewModel().RecordsPerPage() * (PaginationViewModel().CurrentPage() -1) ) + terceros().length ) + '/' + (SearchViewModel().TotalRecords())"></span> registros.
            </caption>
            <thead class="bg-opacity-50 bg-secondary">
                <tr>
                    <th class="text-center text-black">@Html.DisplayName("Nº")</th>
                    <th class="text-black">
                        @Html.DisplayNameFor(model => model.Nombres)
                    </th>
                    <th class="text-black">
                        @Html.DisplayName("Cédula")
                    </th>
                    <th class="text-black">
                        @Html.DisplayName("INSS")
                    </th>
                    <th class="text-center text-black">Acciones</th>
                </tr>
            </thead>
            <tbody class="table-group-divider" data-bind="foreach: terceros">
                <tr>
                    <td class="text-center align-middle fw-bold" data-bind="text: ((($parent.SearchViewModel().Page() - 1) * $parent.SearchViewModel().RecordsPerPage()) + $index() + 1)"></td>
                    <td class="" data-bind="text:(ko.unwrap(Nombres) + ' ' + ko.unwrap(Apellidos))"></td>
                    <td class="" data-bind="text: ko.unwrap(CedulaIdentidad? CedulaIdentidad: '-')"></td>
                    <td class="" data-bind="text: ko.unwrap(NumeroDeInss? NumeroDeInss: '-') "></td>
                    <td class="text-center align-middle">
                        <div class="btn-group btn-group-sm">
                            <button class="btn btn-outline-primary btn-sm" data-bind="click: $parent.addTercero">
                                <span class="fas fa-plus-circle fa-1x"></span>
                            </button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>

        <!--ko if:LoadingRegistros() === false -->
        <div class="mt-3" data-bind="template: { name: 'pagination-template', data: PaginationViewModel }"></div>
        <!--/ko-->
    </div>

    <!--ko if: (terceros().length <= 0 && !LoadingRegistros()) -->
    <div class="card">
        <div class="card-body p-1">
            <div class="alert alert-warning animated flash mb-0" role="alert">
                <p class="mb-0">
                    <span class="fas fa-exclamation-triangle"></span>
                    No se han encontrado registros para mostrar
                </p>
            </div>
        </div>
    </div>

    <!--/ko -->

</template>

