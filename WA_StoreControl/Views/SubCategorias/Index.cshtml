@model WA_StoreControl.ViewModels.IndexSubCategoriasVM

@{
    ViewBag.Title = "SubCategorías";
    @Html.Hidden("JsonData")
}

<div class="row">
    <div class="col-12">
        <div data-bind="template: { name: 'Filter-SubCategoria-Template' }"></div>
    </div>

    <div class="col-md-12 col-sm-12">
        <div class="x_panel">
            <div class="x_title">
                <div class="row align-items-center">
                    <div class="col-6 d-flex justify-content-start">
                        <h2 class="mb-0">
                            <small>Lista de @ViewBag.Title</small>
                        </h2>
                    </div>
                    <div class="col-6 d-flex justify-content-end">
                        <button type="button"
                                class="btn btn-primary"
                                title="Crear Nuevo"
                                data-bind="click: () => ShowModal(null, 'Create')">
                            Crear Nuevo
                        </button>
                    </div>
                </div>
            </div>

            <div class="x_content">
                <div data-bind="template: { name: 'table-SubCategoria-template' }"></div>
            </div>
        </div>
    </div>
</div>

<modal params="ViewModel: ModalViewModel"></modal>

@{ Html.RenderPartial("~/Views/Shared/KnockoutComponents/_LoadingSpinner.cshtml");}

@{ Html.RenderPartial("~/Views/Shared/KnockoutComponents/_Modal.cshtml");}

@{ Html.RenderPartial("~/Views/Shared/KnockoutComponents/_PaginationTemplate.cshtml");}

@{ Html.RenderPartial("~/Views/SubCategorias/_FilterSubCategorias.cshtml", Model.SearchSubCategoriasVM);}

@{ Html.RenderPartial("~/Views/SubCategorias/_TableSubCategorias.cshtml", Model.SubCategoria); }

@{ Html.RenderPartial("~/Views/SubCategorias/_CRUDSubCategorias.cshtml", Model.SubCategoria); }

@section scripts {
    @Scripts.Render("~/bundles/SubCategoria")
}