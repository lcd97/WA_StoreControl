@model ModelosDB.Inventario.SubCategoria

<template id="table-SubCategoria-template">
    <!--ko if: LoadingRegistros() -->
    <div data-bind="template: { name: 'loading-spinner-template', data: { Loading: true, Message: 'Cargando...' } }"></div>
    <!--/ko-->

    <table class="table table-hover" data-bind="if: (!LoadingRegistros() && SubCategorias().length > 0)">
        <caption class="small fw-bold">
            <span data-bind="text: SubCategorias().length"></span> registros en la tabla.
        </caption>
        <thead>
            <tr>
                <th scope="row" class="text-center">
                    #
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Codigo)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Descripcion)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.CategoriaId)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.EsActivo)
                </th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody class="table-group-divider" data-bind="foreach: SubCategorias">
            <tr>
                <td class="text-center align-middle fw-bold" data-bind="text: ((($parent.SearchViewModel().Page() - 1) * $parent.SearchViewModel().RecordsPerPage()) + $index() + 1)"></td>

                <td class="align-middle" data-bind="text:Codigo"></td>
                <td class="align-middle" data-bind="text:Descripcion"></td>
                <td class="align-middle" data-bind="text:DescripcionCategoria"></td>
                <td class="align-middle">
                    <span data-bind="css: EsActivo() ? 'badge text-bg-success' : 'badge text-bg-warning',
                    text: EsActivo() ? 'Activo' : 'Inactivo'"></span>
                </td>

                <td>
                    <button type="button" class="btn btn-outline-primary" title="Editar" data-bind="click: () => { $root.ShowModal($data, 'Edit') }">
                        <i class="fa fa-pencil-square-o"></i>
                    </button>
                    <button type="button" class="btn btn-outline-warning" title="Detalles" data-bind="click: () => { $root.ShowModal($data, 'Details') }">
                        <i class="fa fa-info-circle"></i>
                    </button>
                    <button type="button" class="btn btn-outline-danger" title="Eliminar" data-bind="click: () => { $root.ShowModal($data, 'Delete') }">
                        <i class="fa fa-trash"></i>
                    </button>
                </td>
            </tr>
        </tbody>
    </table>

    <!--ko if: LoadingRegistros() === false -->
    <div class="mt-3" data-bind="template: { name: 'pagination-template', data: PaginationViewModel }"></div>
    <!--/ko-->
    <!--ko if: (SubCategorias().length <= 0 && !LoadingRegistros()) -->
    <div class="alert alert-warning animated flash mb-0" role="alert">
        <p class="mb-0">
            <span class="fas fa-exclamation-triangle"></span>
            No se han encontrado @ViewBag.Title para mostrar
        </p>
    </div>
    <!--/ko -->
</template>