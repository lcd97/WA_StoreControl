
<template id="Filter-DatosEntrada-Template">
    <div class="x_panel">
        <div class="x_title">
            <h2>
                <span class="fas fa-filter"></span>
                <small>Datos de Ingreso</small>
            </h2>
            <div class="col d-flex justify-content-end">
                <button type="button"
                        class="btn btn-primary btn-sm"
                        title="Regresar a Entradas"
                        data-bind="click: $root.Regresar">
                    Regresar
                </button>
            </div>
            <div class="clearfix"></div>
        </div>
        <div class="x_content">
            <div class="row mb-1">
                <div class="col-xs-12 col-sm-12 col-md-5 col-lg-5 mt-2">
                    @Html.Label("Fecha Entrada", new { @class = "fw-bold col-12" })
                    <input type="text" class="form-control" maxlength="15" data-bind="value:FechaEntrada, jqDatepicker: FechaEntrada" />
                </div>

                <div class="col-xs-12 col-sm-12 col-md-5 col-lg-5 mt-2">
                    @Html.Label("Proveedor", new { @class = "fw-bold col-12" })
                    <select class="control-select" data-bind="select2Ajax: $root.ProveedorConfig($data)"></select>
                </div>

                <div class="col-xs-12 col-sm-12 col-md-2 col-lg-2 mt-2 align-content-end align-middle">
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="fas fa-save"></i> Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>
</template>
