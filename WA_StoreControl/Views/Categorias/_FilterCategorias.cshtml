@model WA_StoreControl.ViewModel.SearchCategoriasVM

<template id="Filter-Categoria-Template">
    <div class="x_panel">
        <div class="x_title">
            <h2>
                <span class="fas fa-filter"></span>
                <small>Filtrar Categorías</small>
            </h2>
            <div class="clearfix"></div>
        </div>
        <div class="x_content">
            @using (Html.BeginForm("", "", FormMethod.Post, new { autocomplete = "off", data_bind = "submit: $root.GetFilteredOrPaged, with: SearchViewModel", @id = "form" }))
            {
                <div class="row mb-1">
                    <!--Descripcion-->
                    <div class="col-sm-12 col-md-10 col-lg-10">
                        @Html.LabelFor(model => model.Descripcion, new { @class = "fw-bold" })
                        @Html.TextBoxFor(model => model.Descripcion, new { @class = "form-control form-control-sm", data_bind = "value: Descripcion" })
                    </div>

                    <!--Acciones-->
                    <div class="col d-grid gap-2" data-bind="disableInputs: $root.LoadingRegistros()">
                        <button type="submit" class="btn btn-primary btn-primary btn-sm"> <i class="fa fa-search"></i> Buscar</button>
                        <button type="button" class="btn btn-secondary btn-sm" data-bind="click: $root.CleanFilter"><i class="fas fa-broom"></i> Limpiar</button>
                    </div>
                </div>
            }
        </div>
    </div>
</template>
